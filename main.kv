
#:import NoTransition kivy.uix.screenmanager.NoTransition
<ThickProgressBar>:
    thickness: '20dp'
    canvas:
        # Background bar
        Color:
            rgb: 0.5, 0.5, 0.5
        RoundedRectangle:
            pos: self.pos
            size: self.width, self.height
        # Progress bar (the filling part)
        Color:
            rgb: 0, 1, 0  # Green
        RoundedRectangle:
            pos: self.pos
            size: (self.width * (self.value / float(self.max))) if self.max else 0, self.height

<WindowManager>:
    LoginScreen:
    MainLayout:
<LoginScreen>:
    name: "login"
    BoxLayout:
        orientation: "vertical"
        padding: 50
        spacing: 20
        Label:
            text: "Username"
        TextInput:
            id: username
            multiline: False
        Label:
            text: "Password"
        TextInput:
            id: password
            multiline: False
            password: True
        Button:
            text: "Login"
            on_release: root.verify()

<MainLayout>:
    orientation: 'horizontal'
    name: 'main'
    # Left Panel - Menu
    BoxLayout:
        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.2
            Button:
                text: 'Character'
                on_press: sm.current = 'Character'
            Button:
                text: 'Combat'
                on_press: sm.current = 'Combat'
            Button:
                text: 'Mining'
                on_press: sm.current = 'Mining'
            Button:
                text: 'Smelting'
                on_press: sm.current = 'Smelting'
            Button:
                text: 'Crafting'
                on_press: sm.current = 'Crafting'
            Button:
                text: 'Gathering'
                on_press: sm.current = 'Gathering'
            Button:
                text: 'Cooking'
                on_press: sm.current = 'Cooking'
            Button:
                text: 'sync data'
                on_press: app.sync()
                
        # Right Panel - Content Area
        BoxLayout:
            orientation: 'vertical'
            ScreenManager:
                id: sm
                transition: NoTransition()
                Screen:
                    name: 'Mining'
                    Label:
                        text: 'xp: ' + str(app.xps['mining'])
                    GridLayout:
                        cols: 2
                        Button:
                            text: 'Copper Ore: ' + '\n  ' + str(app.data['copper ore'])
                            on_press: app.send('copper ore')
                        Button:
                            text: 'Iron Ore: ' + '\n  ' + str(app.data['iron ore'])
                            on_press: app.send('iron ore')
                Screen:
                    name: 'Character'
                    Label:
                        text: 'Character'

                Screen:
                    name: 'Combat'
                    Label:
                        text: 'Combat'
                Screen:
                    name: 'Smelting'
                    GridLayout:
                        cols: 2
                        Button:
                            text: 'Copper Ingot: ' + '\n' + str(app.data['copper ingot'])
                            on_press: app.send('copper ingot')
                        Button:
                            text: 'Iron Ingot: ' + '\n' + str(app.data['iron ingot'])
                            on_press: app.send('iron ingot')
                Screen:
                    name: 'Crafting'
                    GridLayout:
                        cols: 2
                        Button:
                            text: 'Copper Armor: ' + '\n' + str(app.data['copper armor'])
                            on_press: app.send('copper armor')
                        Button:
                            text: 'Iron Armor: ' + '\n' + str(app.data['iron armor'])
                            on_press: app.send('iron armor')
                Screen:
                    name: 'Gathering'
                    Label:
                        text: 'Gathering'
                Screen:
                    name: 'Cooking'
                    Label:
                        text: 'Cooking'
            ThickProgressBar:
                id: pb
                value: 0
                size_hint_y: None